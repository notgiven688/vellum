<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <InternalsVisibleTo Include="Vellum.Tests" />
    <EmbeddedResource Include="_package\JetBrainsMono-Regular.ttf"
                      LogicalName="Vellum.Assets.Fonts.JetBrainsMono-Regular.ttf" />
    <EmbeddedResource Include="_package\MaterialSymbolsOutlined.ttf"
                      LogicalName="Vellum.Assets.Fonts.MaterialSymbolsOutlined.ttf" />
    <None Include="_package\THIRD-PARTY-NOTICES.txt"
          Pack="true"
          PackagePath="" />
    <None Include="_package\README.md"
          Pack="true"
          PackagePath="" />
    <None Include="_package\LICENSE.txt"
          Pack="true"
          PackagePath="" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>VellumUI</PackageId>
    <Description>Immediate-mode GUI library for C# with a small renderer API and built-in text rendering.</Description>
    <Authors>notgiven688</Authors>
    <PackageTags>gui;immediate-mode;csharp;dotnet;ui</PackageTags>
    <RepositoryUrl>https://github.com/notgiven688/vellum.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
  </PropertyGroup>

</Project>
